<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CET-6 · 英语学习 · 签到</title>
<style>
  :root {
    --bg: #f5f7fa;
    --card: #ffffff;
    --primary: #5b6abf;
    --primary-light: #e8ebf8;
    --primary-dark: #3f4a8a;
    --accent: #f6a85b;
    --success: #4caf7d;
    --danger: #e57373;
    --text: #2d3748;
    --text-secondary: #718096;
    --border: #e2e8f0;
    --radius: 16px;
    --shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    padding: 20px;
  }
  .app { max-width: 560px; margin: 0 auto; }

  .header { text-align: center; padding: 24px 20px 16px; }
  .header h1 { font-size: 22px; font-weight: 700; letter-spacing: 1px; }
  .header h1 span { color: var(--primary); }
  .header .sub { color: var(--text-secondary); font-size: 13px; margin-top: 2px; }
  .header .today { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }

  .card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px;
    margin-bottom: 14px;
  }
  .card-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tabs {
    display: flex;
    gap: 4px;
    background: var(--bg);
    border-radius: 12px;
    padding: 4px;
    margin-bottom: 14px;
  }
  .tabs button {
    flex: 1;
    padding: 10px 0;
    border: none;
    border-radius: 10px;
    background: transparent;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.25s;
  }
  .tabs button.active {
    background: var(--card);
    color: var(--primary);
    font-weight: 600;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  .checkin-hero { text-align: center; padding: 20px 16px; }
  .checkin-btn {
    width: 88px; height: 88px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, var(--primary), #7c8cdb);
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(91,106,191,0.35);
    margin: 0 auto 14px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
  }
  .checkin-btn:hover { transform: scale(1.05); }
  .checkin-btn:active { transform: scale(0.97); }
  .checkin-btn.done {
    background: linear-gradient(135deg, var(--success), #66d19a);
    box-shadow: 0 4px 20px rgba(76,175,125,0.35);
    cursor: default;
  }
  .checkin-btn.done:hover { transform: none; }
  .checkin-btn .big { font-size: 26px; line-height: 1; }
  .checkin-btn .small { font-size: 11px; font-weight: 400; opacity: 0.9; }
  .cta-text { color: var(--text-secondary); font-size: 13px; margin-top: 2px; }
  .cta-text strong { color: var(--primary); }

  .stats {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .stat-item { text-align: center; }
  .stat-num { font-size: 22px; font-weight: 700; color: var(--primary); }
  .stat-label { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    text-align: center;
  }
  .cal-header { font-size: 12px; color: var(--text-secondary); font-weight: 500; padding: 3px 0; }
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    border-radius: 8px;
    position: relative;
  }
  .cal-day.other { color: #ccc; }
  .cal-day.today { font-weight: 700; color: var(--primary); }
  .cal-day.checked::after {
    content: '';
    position: absolute;
    bottom: 2px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--success);
  }
  .cal-day.today.checked::after { background: var(--primary); }
  .cal-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .cal-nav .month-label { font-size: 14px; font-weight: 600; }
  .cal-nav button {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 10px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
    transition: all 0.2s;
  }
  .cal-nav button:hover { background: var(--primary-light); color: var(--primary); border-color: var(--primary); }

  .daily-badge {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    flex-wrap: wrap;
    gap: 6px;
  }
  .daily-badge .info { font-size: 13px; color: var(--text-secondary); }
  .daily-badge .day-tag {
    background: var(--primary-light);
    color: var(--primary);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
  }
  .daily-search {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 13px;
    margin-bottom: 12px;
    outline: none;
    transition: border 0.2s;
  }
  .daily-search:focus { border-color: var(--primary); }

  .word-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    max-height: 520px;
    overflow-y: auto;
    padding-right: 4px;
  }
  .word-grid::-webkit-scrollbar { width: 4px; }
  .word-grid::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .word-chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 10px;
    background: var(--bg);
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
    gap: 6px;
  }
  .word-chip:hover { background: var(--primary-light); }
  .word-chip .we { font-weight: 600; font-size: 14px; }
  .word-chip .cn-small {
    font-size: 12px;
    color: var(--text-secondary);
    text-align: right;
    max-width: 55%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .word-chip .cn-small.hidden {
    color: transparent;
    background: #e2e8f0;
    border-radius: 3px;
    padding: 1px 6px;
  }
  .word-chip .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .word-chip .status-dot.new { background: #ddd; }
  .word-chip .status-dot.learning { background: var(--accent); }
  .word-chip .status-dot.known { background: var(--success); }

  .words-footer {
    text-align: center;
    margin-top: 10px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .words-footer .count { color: var(--primary); font-weight: 600; }

  .review-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-secondary);
    font-size: 14px;
  }
  .review-empty .big-icon { font-size: 48px; margin-bottom: 12px; }

  .flashcard-container { text-align: center; padding: 8px 0; }
  .flashcard-progress {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }
  .flashcard {
    background: var(--bg);
    border-radius: 16px;
    padding: 40px 24px;
    cursor: pointer;
    transition: all 0.3s;
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    user-select: none;
  }
  .flashcard:hover { border-color: var(--primary-light); }
  .flashcard .fc-en { font-size: 26px; font-weight: 700; }
  .flashcard .fc-cn {
    font-size: 18px;
    color: var(--primary);
    margin-top: 12px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .flashcard .fc-cn.show { opacity: 1; }
  .flashcard .fc-hint { font-size: 13px; color: var(--text-secondary); margin-top: 16px; }

  .fc-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }
  .fc-actions button {
    padding: 10px 28px;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 100px;
  }
  .fc-actions button:active { transform: scale(0.96); }
  .fc-forgot { background: #fde8e8; color: var(--danger); }
  .fc-forgot:hover { background: #f8d0d0; }
  .fc-remember { background: #e8f5ee; color: var(--success); }
  .fc-remember:hover { background: #d0ebdf; }
  .fc-actions button:disabled { opacity: 0.4; cursor: default; }

  .review-summary {
    text-align: center;
    padding: 20px;
  }
  .review-summary .big-icon { font-size: 48px; margin-bottom: 8px; }
  .review-summary .summary-title { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
  .review-summary .summary-stats { display: flex; gap: 24px; justify-content: center; margin: 12px 0; }
  .review-summary .summary-stats div { text-align: center; }
  .review-summary .summary-stats .num { font-size: 20px; font-weight: 700; }
  .review-summary .summary-stats .num.green { color: var(--success); }
  .review-summary .summary-stats .num.red { color: var(--danger); }
  .review-summary .summary-restart {
    margin-top: 12px;
    padding: 8px 24px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card);
    cursor: pointer;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .quiz-area { padding: 12px 0 4px; }
  .quiz-area .q-label { font-size: 13px; color: var(--text-secondary); margin-bottom: 8px; }
  .quiz-area .q-word { font-size: 20px; font-weight: 700; margin-bottom: 10px; }
  .quiz-options { display: flex; flex-direction: column; gap: 6px; }
  .quiz-options button {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--card);
    cursor: pointer;
    font-size: 14px;
    text-align: left;
    transition: all 0.2s;
  }
  .quiz-options button:hover { border-color: var(--primary); background: var(--primary-light); }
  .quiz-options button.correct { border-color: var(--success); background: #eafaf3; color: var(--success); font-weight: 600; }
  .quiz-options button.wrong { border-color: #e53e3e; background: #fff5f5; color: #e53e3e; }
  .quiz-result { margin-top: 8px; font-size: 14px; font-weight: 500; }
  .quiz-result.correct { color: var(--success); }
  .quiz-result.wrong { color: #e53e3e; }
  .quiz-next {
    margin-top: 8px;
    padding: 8px 20px;
    border: none;
    border-radius: 8px;
    background: var(--primary);
    color: #fff;
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s;
  }
  .quiz-next:hover { background: var(--primary-dark); }

  .toast {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-80px);
    padding: 12px 24px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 500;
    background: var(--card);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    transition: transform 0.4s ease;
    z-index: 1000;
    pointer-events: none;
    border: 1px solid var(--border);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
  .toast.success { border-color: var(--success); color: var(--success); }
  .toast.info { border-color: var(--primary); color: var(--primary); }

  @media (max-width: 420px) {
    body { padding: 12px; }
    .card { padding: 16px; }
    .checkin-btn { width: 76px; height: 76px; font-size: 14px; }
    .checkin-btn .big { font-size: 22px; }
    .stats { gap: 20px; }
    .word-grid { grid-template-columns: 1fr; max-height: 400px; }
    .flashcard .fc-en { font-size: 22px; }
  }
</style>
</head>
<body>
<div class="app" id="app">

  <div id="mainApp">

    <div class="header">
      <h1>📚 <span>CET-6</span> 学习</h1>
      <div class="sub">大学英语六级 · 每日 100 词</div>
      <div class="today" id="headerDate"></div>
    </div>

    <div class="card checkin-hero">
      <button class="checkin-btn" id="checkinBtn" onclick="doCheckin()">
        <span class="big" id="checkinIcon">✓</span>
        <span class="small" id="checkinLabel">签到</span>
      </button>
      <div class="cta-text" id="checkinCta">今天还没有签到，<strong>点击签到</strong>开始学习吧！</div>
      <div class="stats">
        <div class="stat-item">
          <div class="stat-num" id="streakNum">0</div>
          <div class="stat-label">连续天数</div>
        </div>
        <div class="stat-item">
          <div class="stat-num" id="totalNum">0</div>
          <div class="stat-label">总签到</div>
        </div>
        <div class="stat-item">
          <div class="stat-num" id="wordProgress">0/0</div>
          <div class="stat-label">已掌握</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="cal-nav">
        <button onclick="changeMonth(-1)">‹ 上月</button>
        <span class="month-label" id="monthLabel">—</span>
        <button onclick="changeMonth(1)">下月 ›</button>
      </div>
      <div class="calendar-grid" id="calendar"></div>
    </div>

    <div class="tabs">
      <button class="active" data-tab="learn" onclick="switchTab('learn')">📖 今日学习</button>
      <button data-tab="review" onclick="switchTab('review')">🔄 复习</button>
      <button data-tab="quiz" onclick="switchTab('quiz')">✍️ 测验</button>
    </div>

    <div class="tab-content active" id="tab-learn">
      <div class="card">
        <div class="daily-badge">
          <span class="info" id="dailyInfo">今日 100 词</span>
          <span class="day-tag" id="dayTag">第 1 天</span>
        </div>
        <input class="daily-search" id="dailySearch" type="text" placeholder="🔍 在当前组中搜索..." oninput="renderDailyWords()">
        <div class="word-grid" id="dailyWords"></div>
        <div class="words-footer">
          已显示 <span class="count" id="shownCount">0</span> 个 · 点击单词可切换释义
        </div>
      </div>
    </div>

    <div class="tab-content" id="tab-review">
      <div class="card">
        <div class="card-title"><span class="icon">🔄</span> 复习回顾</div>
        <div id="reviewContent">
          <div class="review-empty">
            <div class="big-icon">📝</div>
            <div>还没有已学单词，先去今日学习看看吧！</div>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-content" id="tab-quiz">
      <div class="card">
        <div class="quiz-area" id="quizArea">
          <div class="q-label">选出正确的翻译：</div>
          <div class="q-word" id="quizWord">—</div>
          <div class="quiz-options" id="quizOptions"></div>
          <div class="quiz-result" id="quizResult"></div>
          <button class="quiz-next" id="quizNext" onclick="nextQuiz()">下一题 →</button>
        </div>
      </div>
    </div>

    <div class="toast" id="toast"></div>
  </div>
</div>

<script src="cet6_words.js"></script>
<script>
const WORDS_PER_DAY = 100;
const WEEKDAYS = ['日', '一', '二', '三', '四', '五', '六'];
let state = { checkins: [], favorites: [], wordStatus: {} };
let displayMonth = null;
let currentTab = 'learn';
let reviewState = { pool: [], idx: 0, flipped: false, remembered: 0, forgotten: 0, done: false };
let quizState = { word: null, options: [], answered: false, pool: [] };

function loadState() {
  try {
    const raw = localStorage.getItem('eng_learn_cet6');
    if (raw) {
      const d = JSON.parse(raw);
      state.checkins = d.checkins || [];
      state.favorites = d.favorites || [];
      state.wordStatus = d.wordStatus || {};
    }
  } catch (e) {}
}

function saveState() {
  localStorage.setItem('eng_learn_cet6', JSON.stringify({
    checkins: state.checkins,
    favorites: state.favorites,
    wordStatus: state.wordStatus
  }));
}

function getTodayStr() {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const day = String(d.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + day;
}

function getDayNumber() {
  return state.checkins.length;
}

function getTodayBatch() {
  const total = VOCABULARY.length;
  if (total === 0) return [];
  const day = getDayNumber();
  let start = (day * WORDS_PER_DAY) % total;
  const batch = [];
  for (let i = 0; i < WORDS_PER_DAY; i++) {
    batch.push(VOCABULARY[(start + i) % total]);
  }
  return batch;
}

function isCheckedIn() {
  return state.checkins.includes(getTodayStr());
}

function calcStreak() {
  if (state.checkins.length === 0) return 0;
  const sorted = state.checkins.slice().sort().reverse();
  let streak = 0;
  let checkDate = new Date();
  if (sorted[0] !== getTodayStr()) {
    checkDate.setDate(checkDate.getDate() - 1);
  }
  for (let i = 0; i < sorted.length; i++) {
    const y = checkDate.getFullYear();
    const m = String(checkDate.getMonth() + 1).padStart(2, '0');
    const d = String(checkDate.getDate()).padStart(2, '0');
    const expected = y + '-' + m + '-' + d;
    if (sorted[i] === expected) {
      streak++;
      checkDate.setDate(checkDate.getDate() - 1);
    } else break;
  }
  return streak;
}

function doCheckin() {
  if (isCheckedIn()) { showToast('今天已经签到啦！🎉', 'info'); return; }
  state.checkins.push(getTodayStr());
  saveState();
  updateCheckinUI();
  renderCalendar();
  updateDailyBadge();
  renderDailyWords();
  showToast('签到成功！继续加油 💪', 'success');
}

function updateCheckinUI() {
  const btn = document.getElementById('checkinBtn');
  const icon = document.getElementById('checkinIcon');
  const label = document.getElementById('checkinLabel');
  const cta = document.getElementById('checkinCta');
  const streak = document.getElementById('streakNum');
  const total = document.getElementById('totalNum');

  const done = isCheckedIn();
  btn.className = 'checkin-btn' + (done ? ' done' : '');
  icon.textContent = done ? '✅' : '✓';
  label.textContent = done ? '已签到' : '签到';
  cta.innerHTML = done
    ? '今日已签到，继续学习今日词汇吧 📖'
    : '今天还没有签到，<strong>点击签到</strong>开始学习吧！';
  streak.textContent = calcStreak();
  total.textContent = state.checkins.length;

  const knownCount = Object.values(state.wordStatus).filter(s => s === 'known').length;
  document.getElementById('wordProgress').textContent = knownCount + '/' + VOCABULARY.length;
}

function renderCalendar() {
  const now = new Date();
  const year = displayMonth ? displayMonth.year : now.getFullYear();
  const month = displayMonth !== null ? displayMonth.month : now.getMonth();
  document.getElementById('monthLabel').textContent = year + '年' + (month + 1) + '月';

  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();
  const todayStr = getTodayStr();

  let html = WEEKDAYS.map(d => '<div class="cal-header">' + d + '</div>').join('');
  for (let i = 0; i < firstDay; i++) html += '<div class="cal-day other"></div>';
  for (let d = 1; d <= daysInMonth; d++) {
    const ds = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
    let cls = 'cal-day';
    if (ds === todayStr) cls += ' today';
    if (state.checkins.includes(ds)) cls += ' checked';
    html += '<div class="' + cls + '">' + d + '</div>';
  }
  document.getElementById('calendar').innerHTML = html;
}

function changeMonth(delta) {
  const now = new Date();
  let y = displayMonth ? displayMonth.year : now.getFullYear();
  let m = displayMonth !== null ? displayMonth.month : now.getMonth();
  m += delta;
  if (m < 0) { m = 11; y--; }
  if (m > 11) { m = 0; y++; }
  displayMonth = { year: y, month: m };
  renderCalendar();
}

function updateDailyBadge() {
  const day = getDayNumber() + 1;
  document.getElementById('dayTag').textContent = '第 ' + day + ' 天';
  document.getElementById('dailyInfo').textContent = '今日 ' + WORDS_PER_DAY + ' 词 · 已签到 ' + getDayNumber() + ' 天';
}

function renderDailyWords() {
  const batch = getTodayBatch();
  const search = document.getElementById('dailySearch').value.toLowerCase().trim();
  let filtered = batch;
  if (search) {
    filtered = batch.filter(function(w) {
      return w.en.toLowerCase().includes(search) || w.cn.includes(search);
    });
  }

  const container = document.getElementById('dailyWords');
  document.getElementById('shownCount').textContent = filtered.length;

  container.innerHTML = filtered.map(function(w) {
    const status = state.wordStatus[w.en] || 'new';
    const dotClass = status === 'known' ? 'known' : status === 'learning' ? 'learning' : 'new';
    return '<div class="word-chip" onclick="toggleDailyCn(this)">'
      + '<span class="we">' + w.en + '</span>'
      + '<span style="display:flex;align-items:center;gap:6px;">'
      + '<span class="cn-small hidden" data-cn="' + w.cn + '">' + w.cn + '</span>'
      + '<span class="status-dot ' + dotClass + '"></span>'
      + '</span></div>';
  }).join('');
}

function toggleDailyCn(el) {
  const cn = el.querySelector('.cn-small');
  cn.classList.toggle('hidden');
  const wordEl = el.querySelector('.we');
  if (wordEl) {
    const en = wordEl.textContent.trim();
    if (state.wordStatus[en] !== 'known') {
      state.wordStatus[en] = 'learning';
      saveState();
      renderDailyWords();
    }
  }
}

function buildReviewPool() {
  const entries = Object.entries(state.wordStatus);
  const knownWords = [];
  for (let i = 0; i < entries.length; i++) {
    const en = entries[i][0];
    const status = entries[i][1];
    if (status === 'known' || status === 'learning') {
      const found = VOCABULARY.find(function(w) { return w.en === en; });
      if (found) knownWords.push(found);
    }
  }
  return knownWords.sort(function() { return Math.random() - 0.5; });
}

function renderReview() {
  const container = document.getElementById('reviewContent');
  const pool = buildReviewPool();

  if (pool.length === 0) {
    container.innerHTML = '<div class="review-empty">'
      + '<div class="big-icon">📝</div>'
      + '<div>还没有已学单词，先去今日学习看看吧！</div>'
      + '<div style="font-size:12px;margin-top:8px;color:#aaa;">点击今日学习中的单词可标记为学习中</div>'
      + '</div>';
    return;
  }

  reviewState.pool = pool;
  reviewState.idx = 0;
  reviewState.flipped = false;
  reviewState.remembered = 0;
  reviewState.forgotten = 0;
  reviewState.done = false;
  showFlashcard();
}

function showFlashcard() {
  const container = document.getElementById('reviewContent');
  const pool = reviewState.pool;
  const idx = reviewState.idx;
  const done = reviewState.done;

  if (done) {
    const total = reviewState.remembered + reviewState.forgotten;
    const pct = total ? Math.round(reviewState.remembered / total * 100) : 0;
    container.innerHTML = '<div class="review-summary">'
      + '<div class="big-icon">🎉</div>'
      + '<div class="summary-title">复习完成！</div>'
      + '<div class="summary-stats">'
      + '<div><div class="num green">' + reviewState.remembered + '</div><div style="font-size:12px;color:var(--text-secondary);">记得</div></div>'
      + '<div><div class="num red">' + reviewState.forgotten + '</div><div style="font-size:12px;color:var(--text-secondary);">需复习</div></div>'
      + '</div>'
      + '<div style="font-size:13px;color:var(--text-secondary);">正确率 ' + pct + '%</div>'
      + '<button class="summary-restart" onclick="renderReview()">🔄 再来一轮</button>'
      + '</div>';
    return;
  }

  if (idx >= pool.length) {
    reviewState.done = true;
    showFlashcard();
    return;
  }

  const word = pool[idx];
  reviewState.flipped = false;

  container.innerHTML = '<div class="flashcard-container">'
    + '<div class="flashcard-progress">' + (idx + 1) + ' / ' + pool.length + '</div>'
    + '<div class="flashcard" onclick="flipFlashcard()">'
    + '<div class="fc-en">' + word.en + '</div>'
    + '<div class="fc-cn" id="fcCn">' + word.cn + '</div>'
    + '<div class="fc-hint" id="fcHint">👆 点击翻转</div>'
    + '</div>'
    + '<div class="fc-actions">'
    + '<button class="fc-forgot" id="fcForgot" onclick="reviewAnswer(false)" disabled>😅 忘了</button>'
    + '<button class="fc-remember" id="fcRemember" onclick="reviewAnswer(true)" disabled>✅ 记得</button>'
    + '</div></div>';
}

function flipFlashcard() {
  if (reviewState.done) return;
  reviewState.flipped = true;
  document.getElementById('fcCn').classList.add('show');
  document.getElementById('fcHint').textContent = '';
  document.getElementById('fcForgot').disabled = false;
  document.getElementById('fcRemember').disabled = false;
}

function reviewAnswer(remembered) {
  if (!reviewState.flipped) return;
  const word = reviewState.pool[reviewState.idx];
  if (word) {
    state.wordStatus[word.en] = remembered ? 'known' : 'learning';
  }
  if (remembered) reviewState.remembered++;
  else reviewState.forgotten++;
  saveState();
  reviewState.idx++;
  updateCheckinUI();
  showFlashcard();
}

function initQuiz() {
  quizState.pool = VOCABULARY.length > 0 ? VOCABULARY.slice() : [];
  quizState.answered = false;
  nextQuiz();
}

function nextQuiz() {
  if (quizState.pool.length === 0) {
    quizState.pool = VOCABULARY.length > 0 ? VOCABULARY.slice() : [];
  }
  if (quizState.pool.length === 0) return;
  const idx = Math.floor(Math.random() * quizState.pool.length);
  const correct = quizState.pool.splice(idx, 1)[0];
  quizState.word = correct;
  quizState.answered = false;

  let wrongPool = VOCABULARY.filter(function(w) { return w.en !== correct.en; });
  const shuffled = wrongPool.sort(function() { return Math.random() - 0.5; }).slice(0, 3);
  const options = [
    { text: correct.cn, correct: true },
    { text: shuffled[0].cn, correct: false },
    { text: shuffled[1].cn, correct: false },
    { text: shuffled[2].cn, correct: false }
  ].sort(function() { return Math.random() - 0.5; });
  quizState.options = options;

  document.getElementById('quizWord').textContent = correct.en;
  document.getElementById('quizResult').textContent = '';
  document.getElementById('quizResult').className = 'quiz-result';
  document.getElementById('quizNext').style.display = 'none';

  const container = document.getElementById('quizOptions');
  container.innerHTML = options.map(function(opt, i) {
    return '<button data-idx="' + i + '" onclick="answerQuiz(' + i + ')">' + opt.text + '</button>';
  }).join('');
}

function answerQuiz(idx) {
  if (quizState.answered) return;
  quizState.answered = true;
  const correct = quizState.options.find(function(o) { return o.correct; });
  const correctIdx = quizState.options.indexOf(correct);
  const buttons = document.querySelectorAll('#quizOptions button');
  const result = document.getElementById('quizResult');

  buttons.forEach(function(b) { b.style.pointerEvents = 'none'; });
  for (let i = 0; i < buttons.length; i++) {
    if (i === correctIdx) buttons[i].classList.add('correct');
    if (i === idx && idx !== correctIdx) buttons[i].classList.add('wrong');
  }

  if (quizState.options[idx].correct) {
    result.textContent = '✅ 回答正确！';
    result.className = 'quiz-result correct';
  } else {
    result.textContent = '❌ 正确答案是：' + correct.text;
    result.className = 'quiz-result wrong';
  }
  document.getElementById('quizNext').style.display = 'inline-block';
}

function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tabs button').forEach(function(b) {
    b.classList.toggle('active', b.dataset.tab === tab);
  });
  document.querySelectorAll('.tab-content').forEach(function(el) {
    el.classList.toggle('active', el.id === 'tab-' + tab);
  });
  if (tab === 'review') renderReview();
  if (tab === 'quiz') initQuiz();
}

let toastTimer = null;
function showToast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast ' + type + ' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function() { el.classList.remove('show'); }, 2200);
}

function init() {
  loadState();
  VOCABULARY = WORDS_DATA;
  if (!Array.isArray(VOCABULARY) || VOCABULARY.length === 0) {
    document.body.innerHTML = '<div style="text-align:center;padding:60px 20px;color:#e57373;">'
      + '<div style="font-size:48px;margin-bottom:12px;">⚠️</div>'
      + '<div style="font-size:16px;font-weight:600;">词库加载失败</div>'
      + '<div style="font-size:13px;margin-top:6px;color:var(--text-secondary);">请确认 cet6_words.js 文件存在</div>'
      + '</div>';
    return;
  }

  const now = new Date();
  document.getElementById('headerDate').textContent =
    now.getFullYear() + '年' + (now.getMonth() + 1) + '月' + now.getDate() + '日 星期' + WEEKDAYS[now.getDay()];

  updateCheckinUI();
  renderCalendar();
  updateDailyBadge();
  renderDailyWords();
  renderReview();
  initQuiz();
}

init();
</script>
</body>
</html>
